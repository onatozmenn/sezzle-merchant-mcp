{
  "name": "sezzle-merchant-mcp",
  "version": "0.1.0",
  "description": "Unofficial, experimental, security-focused MCP server for Sezzle merchant operations.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onatozmenn/sezzleops-mcp.git"
  },
  "homepage": "https://github.com/onatozmenn/sezzleops-mcp#readme",
  "bugs": {
    "url": "https://github.com/onatozmenn/sezzleops-mcp/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "sezzle-ops": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "ARCHITECTURE.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "inspect-tools": "tsx scripts/inspect-tools.ts",
    "inspect-tools:write": "tsx scripts/inspect-tools.ts --write docs/TOOL_INVENTORY.md",
    "inspect-tools:check": "tsx scripts/inspect-tools.ts --check docs/TOOL_INVENTORY.md",
    "docker:build": "docker build -t sezzle-merchant-mcp .",
    "docker:run": "docker run --rm -i --env-file .env sezzle-merchant-mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "csv-parse": "^7.0.1",
    "express": "^5.2.1",
    "lossless-json": "^4.3.0",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
