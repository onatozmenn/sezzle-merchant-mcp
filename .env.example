SEZZLE_ENV=sandbox
SEZZLE_API_BASE_URL=
SEZZLE_MERCHANT_UUID=
SEZZLE_API_KEY=
SEZZLE_API_SECRET=
SEZZLE_WEBHOOK_SECRET=
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3000
MCP_HTTP_AUTH_TOKEN=
MCP_HTTP_ALLOWED_HOSTS=
MCP_HTTP_ALLOWED_ORIGINS=
LOG_LEVEL=info
SEZZLE_READ_ONLY=true
SEZZLE_REQUIRE_CONFIRMATION=true
SEZZLE_PERMISSION_PROFILE=read
SEZZLE_REQUEST_TIMEOUT_MS=10000
SEZZLE_MAX_CONCURRENCY=5
SEZZLE_MAX_RETRIES=2
SEZZLE_PREVIEW_TTL_SECONDS=300
SEZZLE_STORAGE=memory
SEZZLE_SQLITE_PATH=./data/sezzle-ops.db